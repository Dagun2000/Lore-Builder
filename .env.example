# Which LLM provider every call in the app uses. One of: openai (default), anthropic, ollama, google.
LLM_PROVIDER=openai

# --- OpenAI ---
OPENAI_API_KEY=
# OPENAI_SIMPLE_MODEL=gpt-5.4-mini
# OPENAI_REASONING_MODEL=gpt-5.6-terra

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
# ANTHROPIC_SIMPLE_MODEL=claude-haiku-4-5
# ANTHROPIC_REASONING_MODEL=claude-sonnet-5

# --- Ollama (local, no API key needed) ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_SIMPLE_MODEL=llama3.1
# OLLAMA_REASONING_MODEL=llama3.1

# --- Google (Gemini) ---
GOOGLE_API_KEY=
# GOOGLE_SIMPLE_MODEL=gemini-2.5-flash
# GOOGLE_REASONING_MODEL=gemini-2.5-pro

# --- World language ---
# The language the AI reads/writes/reasons in for THIS project, and the
# anchor that stored enum values (character.gender options, etc.) are
# checked against. Set this ONCE, before you start entering any data.
# Changing it mid-project will likely break things: already-saved enum
# values won't match a freshly-translated options list, and the AI will
# start writing new content in a different language than everything
# already in the world. This is separate from the interface language
# (menus/buttons), which stays freely toggleable at runtime regardless.
WORLD_LANGUAGE=ko
